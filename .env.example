# API Configuration
# Use local development server or production API
NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL=https://melon-core.onrender.com

# Google Maps API Key (for geocoding and geospatial features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Cloudinary Configuration (for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name

# Platform Administration
# IMPORTANT: Set this to the MongoDB _id of your platform's admin organization
# Only users from this organization will see the Platform Administration tab in Settings
# This should match the MELON_ORG_ID value in your backend .env
NEXT_PUBLIC_MELON_ORG_ID=your_melon_organization_id_here
